      "text": "📋 ملاحظات مهمة — جميع الأنظمة",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "📋 ملاحظات مهمة — جميع الأنظمة",
      "autoResize": true,
