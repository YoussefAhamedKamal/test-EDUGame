    },
    {
      "id": "common_text",
      "type": "text",
      "x": 100,
      "y": 2100,
      "width": 3340,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "p2",
      "roundness": null,
      "seed": 942,
      "version": 1,
      "versionNonce": 942,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "التحقق من التثبيت:\n   node --version    ← يجب أن يظهر v18+ أو v20+\n   npm --version     ← يجب أن يظهر 9+ أو 10+\n   git --version     ← يجب أن يظهر 2+\n\n    في حال ظهرت أخطاء:\n• \"node: not found\" ← أعد تشغيل Terminal بعد التثبيت\n• \"npm: not found\" ← Node.js غير مُثبّت بشكل صحيح\n• \"permission denied\" ← استخدم sudo (Linux/Mac) أو شغّل كـ Admin (Windows)\n• \"port 5173 in use\" ← اكتب npm run dev -- --port 3000\n\n    للنشر على الإنترنت:\n• GitHub: اضغط \"Upload to GitHub\" في لوحة التحكم\n• Cloudflare Pages: يتطلب حساب مجاني + GitHub\n• Netlify: بديل مجاني (拖 أفلام dist/)\n\n    للمساعدة:\n• GitHub Issues: https://github.com/YoussefAhamedKamal/cyber-guardians-mobile/issues\n• أو اسأل AI Assistant داخل اللعبة",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "التحقق من التثبيت:\n   node --version    ← يجب أن يظهر v18+ أو v20+\n   npm --version     ← يجب أن يظهر 9+ أو 10+\n   git --version     ← يجب أن يظهر 2+\n\n    في حال ظهرت أخطاء:\n• \"node: not found\" ← أعد تشغيل Terminal بعد التثبيت\n• \"npm: not found\" ← Node.js غير مُثبّت بشكل صحيح\n• \"permission denied\" ← استخدم sudo (Linux/Mac) أو شغّل كـ Admin (Windows)\n• \"port 5173 in use\" ← اكتب npm run dev -- --port 3000\n\n    للنشر على الإنترنت:\n• GitHub: اضغط \"Upload to GitHub\" في لوحة التحكم\n• Cloudflare Pages: يتطلب حساب مجاني + GitHub\n• Netlify: بديل مجاني (拖 أفلام dist/)\n\n    للمساعدة:\n• GitHub Issues: https://github.com/YoussefAhamedKamal/cyber-guardians-mobile/issues\n• أو اسأل AI Assistant داخل اللعبة",
      "autoResize": true,
      "lineHeight": 1.25
    },
