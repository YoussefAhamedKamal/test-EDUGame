      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "الخطوة 1: تثبيت Homebrew (مدير الحزم)\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. افتح Terminal (من Spotlight: Cmd+Space)\n2. اكتب:\n   /bin/bash -c \"$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"\n3. اضغط Enter واتبع التعليمات\n4. أعد تشغيل Terminal\n\nالخطوة 2: تثبيت Node.js + Git\n━━━━━━━━━━━━━━━━━━━━━━━━━\nفي Terminal اكتب:\n   brew install node git\n\nالخطوة 3: تثبيت المحرر (اختياري)\n━━━━━━━━━━━━━━━━━━━━━━━━━\n• VS Code: brew install --cask visual-studio-code\n• أو حمّل من: https://code.visualstudio.com\n\nالخطوة 4: تشغيل اللعبة\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. افتح Terminal\n2. اكتب:\n   git clone https://github.com/YoussefAhamedKamal/cyber-guardians-mobile.git\n   cd cyber-guardians-mobile\n   npm install\n   npm run dev\n3. افتح المتصفح على:\n   http://localhost:5173",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "الخطوة 1: تثبيت Homebrew (مدير الحزم)\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. افتح Terminal (من Spotlight: Cmd+Space)\n2. اكتب:\n   /bin/bash -c \"$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"\n3. اضغط Enter واتبع التعليمات\n4. أعد تشغيل Terminal\n\nالخطوة 2: تثبيت Node.js + Git\n━━━━━━━━━━━━━━━━━━━━━━━━━\nفي Terminal اكتب:\n   brew install node git\n\nالخطوة 3: تثبيت المحرر (اختياري)\n━━━━━━━━━━━━━━━━━━━━━━━━━\n• VS Code: brew install --cask visual-studio-code\n• أو حمّل من: https://code.visualstudio.com\n\nالخطوة 4: تشغيل اللعبة\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. افتح Terminal\n2. اكتب:\n   git clone https://github.com/YoussefAhamedKamal/cyber-guardians-mobile.git\n   cd cyber-guardians-mobile\n   npm install\n   npm run dev\n3. افتح المتصفح على:\n   http://localhost:5173",
