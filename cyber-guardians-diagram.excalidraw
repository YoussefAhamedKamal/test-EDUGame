      "versionNonce": 932,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "الخطوة 1: تحديث النظام\n━━━━━━━━━━━━━━━━━━━━━━━━━\nsudo apt update && sudo apt upgrade -y\n\nالخطوة 2: تثبيت Node.js + Git\n━━━━━━━━━━━━━━━━━━━━━━━━━\n# Node.js (من NodeSource)\ncurl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash -\nsudo apt install -y nodejs\n\n# Git\nsudo apt install -y git\n\n(لـ Fedora: استبدل apt بـ dnf)\n\nالخطوة 3: تثبيت المحرر (اختياري)\n━━━━━━━━━━━━━━━━━━━━━━━━━\n# VS Code\nsudo snap install code --classic\n# أو حمّل من: https://code.visualstudio.com\n\nالخطوة 4: تشغيل اللعبة\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. افتح Terminal\n2. اكتب:\n   git clone https://github.com/YoussefAhamedKamal/cyber-guardians-mobile.git\n   cd cyber-guardians-mobile\n   npm install\n   npm run dev\n3. افتح المتصفح على:\n   http://localhost:5173",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "الخطوة 1: تحديث النظام\n━━━━━━━━━━━━━━━━━━━━━━━━━\nsudo apt update && sudo apt upgrade -y\n\nالخطوة 2: تثبيت Node.js + Git\n━━━━━━━━━━━━━━━━━━━━━━━━━\n# Node.js (من NodeSource)\ncurl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash -\nsudo apt install -y nodejs\n\n# Git\nsudo apt install -y git\n\n(لـ Fedora: استبدل apt بـ dnf)\n\nالخطوة 3: تثبيت المحرر (اختياري)\n━━━━━━━━━━━━━━━━━━━━━━━━━\n# VS Code\nsudo snap install code --classic\n# أو حمّل من: https://code.visualstudio.com\n\nالخطوة 4: تشغيل اللعبة\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. افتح Terminal\n2. اكتب:\n   git clone https://github.com/YoussefAhamedKamal/cyber-guardians-mobile.git\n   cd cyber-guardians-mobile\n   npm install\n   npm run dev\n3. افتح المتصفح على:\n   http://localhost:5173",
