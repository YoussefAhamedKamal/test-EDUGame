    {
      "id": "sys_text",
      "type": "text",
      "x": 2930,
      "y": 820,
      "width": 690,
      "height": 380,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
