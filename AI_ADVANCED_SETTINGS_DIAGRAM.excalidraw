      "versionNonce": 315,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "كيف يعمل AI (التدفق):\n━━━━━━━━━━━━━━━━━━\n1️⃣ طلب المستخدم\n2️⃣ FACULTY_SYSTEM_PROMPT\n3️⃣ AI يولد JSON\n4️⃣ applyUpdates() يطبّق\n5️⃣ contentStore يحفظ\n6️⃣ اللعبة تعرض التعديل",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "كيف يعمل AI (التدفق):\n━━━━━━━━━━━━━━━━━━\n1️⃣ طلب المستخدم\n2️⃣ FACULTY_SYSTEM_PROMPT\n3️⃣ AI يولد JSON\n4️⃣ applyUpdates() يطبّق\n5️⃣ contentStore يحفظ\n6️⃣ اللعبة تعرض التعديل",
