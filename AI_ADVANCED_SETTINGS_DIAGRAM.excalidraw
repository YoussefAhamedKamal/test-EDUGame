      "updated": 1,
      "link": null,
      "locked": false,
      "text": "ملاحظات:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n⚠️ Google Drive API له حدود مجانية\n⚠️ التوكن ينتهي بعد ساعة — يتجدد تلقائياً\n⚠️ الملفات تُرفع إلى مجلد \"Cyber Guardians\"",
