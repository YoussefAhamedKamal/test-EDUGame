      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "أقسام صفحة الإعدادات (8 أقسام):\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n🎨 Visual — السمة، الألوان، الحدود، الخطوط، الحجم\n🔊 Audio — كتم الصوت، صوت الموسيقى/المؤثرات\n⌨️ Controls — إظهار المؤشر، tooltips\n🎭 Characters — أسماء الشخصيات والأدوار والألوان\n📹 Custom Videos — فيديو لكل شخصية + فيديو الاحتفال\n🔤 Fonts — خط الأساسي/العناوين/أحادي العرض (9 خطوط)\n🎮 Gameplay — الصعوبة، إظهار النقاط، إظهار combo\n🗑️ Reset — إعادة ضبط الإعدادات، مسح كل البيانات",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "أقسام صفحة الإعدادات (8 أقسام):\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n🎨 Visual — السمة، الألوان، الحدود، الخطوط، الحجم\n🔊 Audio — كتم الصوت، صوت الموسيقى/المؤثرات\n⌨️ Controls — إظهار المؤشر، tooltips\n🎭 Characters — أسماء الشخصيات والأدوار والألوان\n📹 Custom Videos — فيديو لكل شخصية + فيديو الاحتفال\n🔤 Fonts — خط الأساسي/العناوين/أحادي العرض (9 خطوط)\n🎮 Gameplay — الصعوبة، إظهار النقاط، إظهار combo\n🗑️ Reset — إعادة ضبط الإعدادات، مسح كل البيانات",
