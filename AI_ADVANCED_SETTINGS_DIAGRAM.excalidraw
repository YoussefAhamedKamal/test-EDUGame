      "versionNonce": 413,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "التبويبات:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n🎮 اللعبة — العنوان، الإصدار، الصعوبة، الوقت، الأرواح، التلميحات\n📊 المستويات — 7 مستويات مع intro/outro ونقاط\n👤 الشخصيات — 5 شخصيات مع أسماء وأدوار وألوان\n📁 ملفات — محرر أي ملف (جديد!) 🆕\n⚙ JSON — تحرير JSON مباشرة\n📋 الكل — عرض شامل",
      "fontSize": 12,
